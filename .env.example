# =====================================================================
# RiceLayer environment configuration (EXAMPLE)
# ---------------------------------------------------------------------
# Copy this file to `.env` and fill in real values locally.
# NEVER commit your real `.env`. NEVER put secrets in extension code.
# These variables are read ONLY by the backend (apps/server).
# =====================================================================

# --- AI provider (Google Gemini) ---
# Create a key at https://aistudio.google.com/app/apikey
# Leave empty to run with the built-in mock provider (no AI required).
# Example placeholder format: GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- App / server ---
APP_URL=http://localhost:3000
PORT=8787

# =====================================================================
# Free-for-everyone AI cost controls
# ---------------------------------------------------------------------
# RiceLayer is free and open source. To keep the shared, cloud-backed AI
# provider affordable, the backend enforces a HARD monthly spend ceiling.
# These only bound cost; no feature is ever gated behind them.
# =====================================================================

# Hard ceiling on estimated AI spend per calendar month (USD).
MONTHLY_BUDGET_USD=20
# Portion of the budget reserved for priority (owner) callers (USD).
PRIORITY_RESERVE_USD=5
# Estimated cost per AI generation (USD) used for budget accounting.
EST_COST_PER_GENERATION_USD=0.002
# Optional file to persist budget usage across restarts.
BUDGET_STATE_FILE=

# Per-IP requests/minute for AI generation (anonymous vs priority).
RATE_LIMIT_PER_MINUTE=20
PRIORITY_RATE_LIMIT_PER_MINUTE=120

# --- Priority access (owner) ---
# The project owner can keep guaranteed access even when the shared public
# budget is exhausted. Set OWNER_EMAIL for reference and add one or more
# comma-separated secret keys; the matching key is entered in the extension
# Options page and sent as the `x-ricelayer-key` header. Anonymous use never
# needs a key.
OWNER_EMAIL=cimmonster1@gmail.com
PRIORITY_ACCESS_KEYS=
