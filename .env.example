# =====================================================================
# RiceLayer environment configuration (EXAMPLE)
# ---------------------------------------------------------------------
# Copy this file to `.env` and fill in real values locally.
# NEVER commit your real `.env`. NEVER put secrets in extension code.
# Backend (apps/server) variables are read at RUNTIME by the server.
# The VITE_API_URL variable is read at BUILD TIME by the extension build.
# =====================================================================

# ---------------------------------------------------------------------
# EXTENSION BUILD-TIME CONFIG (apps/extension)
# ---------------------------------------------------------------------
# Backend base URL the packaged extension talks to. This is baked into the
# build AND used to generate the manifest's required host_permissions.
#
#   - Local development (default if unset): http://localhost:8787
#   - Production: set to your deployed API origin BEFORE packaging, e.g.
#       VITE_API_URL=https://api.ricelayer.app
#
# IMPORTANT: this must be set in the shell/CI environment when you run
# `npm run release:extension` (or build:extension/package:extension).
# Example:
#   VITE_API_URL=https://api.ricelayer.app npm run release:extension
VITE_API_URL=http://localhost:8787

# ---------------------------------------------------------------------
# BACKEND RUNTIME CONFIG (apps/server)
# ---------------------------------------------------------------------

# --- AI provider (Google Gemini) ---
# Create a key at https://aistudio.google.com/app/apikey
# Leave empty to run with the built-in mock provider (no AI required).
# Example placeholder format: GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Gemini hard spend cap ---
# RiceLayer is fully free. Real Gemini usage is bounded by a HARD dollar cap.
# Default and maximum is $20 (the code clamps any larger value down to 20).
# Once the estimated cumulative spend reaches the cap, the server stops calling
# Gemini and serves the built-in safe fallback theme instead.
GEMINI_BUDGET_USD=20
# Optional price overrides (USD per 1M tokens) used to estimate spend.
# Defaults target gemini-2.5-flash. Adjust if Google's pricing changes.
GEMINI_PRICE_INPUT_PER_MTOK=0.30
GEMINI_PRICE_OUTPUT_PER_MTOK=2.50

# --- App / server ---
APP_URL=http://localhost:3000
PORT=8787
