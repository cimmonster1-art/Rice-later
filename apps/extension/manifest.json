{
  "manifest_version": 3,
  "name": "RiceLayer",
  "description": "Rice any website without breaking it.",
  "version": "0.1.0",
  "minimum_chrome_version": "110",
  "action": {
    "default_title": "RiceLayer",
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_page": "options.html",
  "permissions": ["activeTab", "scripting", "storage"],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "host_permissions": ["http://localhost:8787/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
